# Copy this file to `.env` and adjust the values for your environment.
#
#   cp .env.example .env

# PostgreSQL (Docker Compose)
POSTGRES_USER=safecheck
POSTGRES_PASSWORD=safecheck
POSTGRES_DB=safecheck
POSTGRES_PORT=5432

# Prisma connection string — must match the POSTGRES_* values above.
DATABASE_URL="postgresql://safecheck:safecheck@localhost:5432/safecheck?schema=public"
